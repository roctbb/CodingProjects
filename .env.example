APP_NAME=Laravel
APP_ENV=local
RECAPTCHA_ENABLE=false
EMAIL_VERIF_ENABLE=false
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

USE_INTEGRITY=true

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=larasite
DB_USERNAME=root
DB_PASSWORD=pwd

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

GEEKPASTE_URL=https://paste.geekclass.ru
GEEKPASTE_API_KEY=

GPT_KEY=
GPT_MODEL=gpt-5-mini
GPT_GATEWAY=https://gpt-gateway.ai.medsenger.ru:4443/v1/responses

TELEGRAM_BOT_TOKEN=
